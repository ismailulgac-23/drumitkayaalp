generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin/User Model
model User {
  id            String    @id @default(uuid())
  phoneNumber   String?   @unique
  email         String?   @unique
  password      String?
  name          String?
  userType      String? // PROVIDER, RECEIVER
  isAdmin       Boolean   @default(false)
  isActive      Boolean   @default(true)
  profileImage  String?
  companyName   String?
  address       String?
  bio           String?
  location      String?
  rating        Float     @default(0)
  ratingCount   Int       @default(0)
  responseTime  Int? // minutes
  memberSince   DateTime?
  completedJobs Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  categories   UserCategory[]
  appointments Appointment[]
  testimonials Testimonial[]

  @@index([email])
  @@index([phoneNumber])
  @@index([isAdmin])
}

// Doctor Model
model Doctor {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String?
  specialty String? // Uzmanlık alanı
  bio       String?
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  appointments Appointment[]

  @@index([isActive])
}

// Patient Model
model Patient {
  id        String    @id @default(uuid())
  name      String
  phone     String
  email     String?
  birthDate DateTime?
  gender    String? // Erkek, Kadın
  address   String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  appointments Appointment[]

  @@index([phone])
  @@index([email])
}

// Service Model
model Service {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  price       Float?
  duration    String? // "30 dakika", "1 saat" gibi
  image       String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  appointments Appointment[]

  @@index([isActive])
  @@index([order])
}

// Appointment Model
model Appointment {
  id          String   @id @default(uuid())
  patientId   String
  doctorId    String?
  serviceId   String?
  name        String // Hasta adı (formdan gelen)
  phone       String // Hasta telefonu
  email       String?
  date        DateTime
  time        String // "09:00", "10:30" gibi
  serviceName String? // Hizmet adı (formdan gelen)
  doctorName  String? // Doktor adı (formdan gelen)
  notes       String?  @db.Text
  status      String   @default("Planlandı") // Planlandı, Bekliyor, Tamamlandı, İptal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  patient Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id])
  userId  String?

  @@index([patientId])
  @@index([doctorId])
  @@index([serviceId])
  @@index([date])
  @@index([status])
}

// Testimonial Model
model Testimonial {
  id          String   @id @default(uuid())
  patientName String
  rating      Int // 1-5 arası
  comment     String   @db.Text
  avatarUrl   String?  // Kullanıcı avatar görseli
  date        DateTime @default(now())
  isActive    Boolean  @default(true)
  userId      String? // İsteğe bağlı: User ile ilişki
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([date])
}

// FAQ Model
model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

// BeforeAfter Model
model BeforeAfter {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  beforeImage String
  afterImage  String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

// Category Model (mevcut yapıdan)
model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users UserCategory[]

  @@index([isActive])
}

// UserCategory Model (mevcut yapıdan)
model UserCategory {
  id         String   @id @default(uuid())
  userId     String
  categoryId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId])
  @@index([categoryId])
}

// City Model (mevcut yapıdan - gerekirse)
model City {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// Newsletter Model
model Newsletter {
  id        String   @id @default(uuid())
  email     String
  name      String?
  isActive  Boolean  @default(true)
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email])
  @@index([email])
  @@index([isActive])
}

// ContactChannel Model
model ContactChannel {
  id          String   @id @default(uuid())
  type        String   // phone, whatsapp, email, address, social_media
  label       String   // "Telefon", "WhatsApp", "Email" vb.
  value       String   // Gerçek değer (numara, email, link vb.)
  icon        String?   // İkon adı veya URL
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([order])
}

// Logo Model
model Logo {
  id          String   @id @default(uuid())
  type        String   // header, footer, favicon, og_image
  name        String   // Logo adı/etiket
  url         String   // Logo URL'si (upload edilen dosya yolu)
  alt         String?  // Alt text
  width       Int?     // Genişlik
  height      Int?     // Yükseklik
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type])
  @@index([type])
  @@index([isActive])
}

// Home Intro Model (Anasayfa Intro)
model HomeIntro {
  id             String   @id @default(uuid())
  smallTitle     String?  // Küçük başlık
  mainTitle      String   // Ana başlık
  subTitle       String?  // Alt başlık
  description    String?  @db.Text // Alt yazı
  buttonText     String?  // Buton adı
  buttonLink     String?  // Buton link
  backgroundImage String? // Intro arkaplan
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
}

// Marquee Item Model (Anasayfa Marquee)
model MarqueeItem {
  id        String   @id @default(uuid())
  text      String   // Marquee metni
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

// Home About Model (Anasayfa About Bölümü)
model HomeAbout {
  id          String   @id @default(uuid())
  image       String?  // Fotoğraf
  smallTitle  String?  // Küçük üst başlık
  title       String?  // Başlık
  content     String?  @db.Text // Content alanı
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// Skill Model (Uzmanlık Alanları)
model Skill {
  id          String   @id @default(uuid())
  percentage  Int       // Yüzdelik (0-100)
  title       String    // Alt başlık
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([order])
}

// Marquee2 Item Model (Marq2 Component)
model Marquee2Item {
  id        String   @id @default(uuid())
  text      String   // Marquee metni
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

// About Page Intro Model (Hakkımızda Intro)
model AboutPageIntro {
  id          String   @id @default(uuid())
  image       String?  // Fotoğraf
  title       String?  // Başlık
  content     String?  @db.Text // Content alanı
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// Contact Map Model (İletişim Harita)
model ContactMap {
  id          String   @id @default(uuid())
  iframeCode  String   @db.Text // Harita iframe kodu
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}
